<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1024</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>智能花盆摆放控制系统</string>
  </property>
  <property name="styleSheet">
   <string>
    QMainWindow { background-color: #F0F2F5; }
    
    /* 容器组通用样式 */
    QGroupBox {
        background-color: #FFFFFF;
        border: 2px solid #DCDFE6;
        border-radius: 15px;
        margin-top: 20px;
        font-family: "Microsoft YaHei";
        font-weight: bold;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        subcontrol-position: top left;
        padding: 5px 15px;
        color: #606266;
        font-size: 16px;
    }

    /* --- 数据区色块卡片 --- */
    QFrame#LatCard { background-color: #E3F2FD; border: 2px solid #2196F3; border-radius: 12px; }
    QFrame#LonCard { background-color: #E8F5E9; border: 2px solid #4CAF50; border-radius: 12px; }
    QFrame#YawCard { background-color: #FFFDE7; border: 2px solid #FBC02D; border-radius: 12px; }
    QFrame#CountCard { background-color: #F3E5F5; border: 2px solid #9C27B0; border-radius: 12px; }

    /* --- 设置区内部色块卡片 --- */
    QFrame#SpacingCard { background-color: #E0F7FA; border: 1px solid #00BCD4; border-radius: 10px; }
    QFrame#ModeCard { background-color: #FCE4EC; border: 1px solid #F06292; border-radius: 10px; }

    /* 文本样式 */
    QLabel { color: #303133; font-family: "Microsoft YaHei"; font-size: 16px; }
    QLabel#LatitudeValueLabel, QLabel#LongitudeValueLabel, QLabel#YawAngleValueLabel, QLabel#PotCountValueLabel {
        font-family: "Consolas"; font-size: 22px; font-weight: bold; color: #2D3436;
    }

    /* 按钮极大化设计 */
    QPushButton#SettingLabel { 
        background-color: #546E7A; color: white; border-radius: 15px; 
        min-height: 80px; font-size: 24px; font-weight: bold;
    }
    QPushButton#StartLabel { 
        background-color: #1976D2; color: white; border-radius: 15px; 
        min-height: 100px; font-size: 28px; font-weight: bold;
    }
    QPushButton:pressed { background-color: #263238; }

    /* 输入框尺寸调整 */
    QSpinBox, QComboBox {
        min-height: 55px;
        font-size: 20px;
        border: 2px solid #DCDFE6;
        border-radius: 8px;
        background-color: #FFFFFF;
    }

    /* ----- 系统设置界面横屏设计 ----- */
    QFrame#SettingsOverlay {
        background-color: rgba(240, 242, 245, 0.98);
        border-radius: 15px;
    }
    
    /* 顶部标签栏 */
    QFrame#SettingsTabBar {
        background-color: #2C3E50;
        border-radius: 12px;
        min-height: 60px;
    }
    QPushButton#TabSystemInfo, QPushButton#TabParams, QPushButton#TabDeveloper, 
    QPushButton#TabLog, QPushButton#TabFirmware {
        background-color: transparent;
        color: #BDC3C7;
        font-size: 20px;
        font-weight: bold;
        border: none;
        border-radius: 8px;
        padding: 8px 20px;
        min-width: 100px;
    }
    QPushButton#TabSystemInfo:hover, QPushButton#TabParams:hover, QPushButton#TabDeveloper:hover, 
    QPushButton#TabLog:hover, QPushButton#TabFirmware:hover {
        background-color: #34495E;
        color: #ECF0F1;
    }
    QPushButton#TabSystemInfo:checked, QPushButton#TabParams:checked, QPushButton#TabDeveloper:checked, 
    QPushButton#TabLog:checked, QPushButton#TabFirmware:checked {
        background-color: #3498DB;
        color: white;
    }
    
    /* 内容区域卡片 */
    QFrame#SettingsContentArea {
        background-color: #FFFFFF;
        border-radius: 20px;
    }
    
    /* 信息卡片样式 */
    QFrame#InfoCard, QFrame#HardwareCard {
        background-color: #F8F9FA;
        border-radius: 15px;
        border: 1px solid #E0E0E0;
    }
    QLabel#SoftwareTitle, QLabel#HardwareTitle {
        font-size: 22px;
        font-weight: bold;
        color: #2C3E50;
        padding: 12px;
        background-color: #ECF0F1;
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
    }
    
    /* 信息行样式 */
    QFrame#InfoRow1, QFrame#InfoRow2, QFrame#InfoRow3,
    QFrame#HardwareRow1, QFrame#HardwareRow2, QFrame#HardwareRow3, QFrame#HardwareRow4 {
        background-color: transparent;
        min-height: 45px;
    }
    QLabel#labelVersion, QLabel#labelAuthor, QLabel#labelBuild,
    QLabel#labelPlatform, QLabel#labelProtocol, QLabel#labelMotor, QLabel#labelSensor {
        font-size: 18px;
        color: #7F8C8D;
        min-width: 120px;
    }
    QLabel#VersionValue, QLabel#AuthorValue, QLabel#BuildValue,
    QLabel#PlatformValue, QLabel#ProtocolValue, QLabel#MotorValue, QLabel#SensorValue {
        font-size: 20px;
        color: #2C3E50;
        font-weight: bold;
        background-color: #FFFFFF;
        padding: 6px 15px;
        border-radius: 8px;
        border: 1px solid #BDC3C7;
    }
    
    /* 开发者模式按钮 */
    QPushButton#DevModeBtn {
        background-color: #E74C3C;
        color: white;
        border-radius: 12px;
        font-size: 22px;
        font-weight: bold;
        min-height: 65px;
    }
    QPushButton#DevModeBtn:hover {
        background-color: #C0392B;
    }
    
    /* 返回按钮 */
    QPushButton#CloseSettingsBtn {
        background-color: #95A5A6;
        color: white;
        border-radius: 12px;
        font-size: 22px;
        font-weight: bold;
        min-height: 65px;
        min-width: 160px;
    }
    QPushButton#CloseSettingsBtn:hover {
        background-color: #7F8C8D;
    }
    
    /* 警告标签 */
    QLabel#DevWarningLabel {
        color: #E74C3C;
        font-size: 16px;
        padding: 8px;
        background-color: #FDEDEC;
        border-radius: 10px;
    }
    
    /* 密码对话框样式 */
    QFrame#passwordDialogFrame {
        background-color: rgba(0, 0, 0, 150);
        border-radius: 15px;
    }
    QFrame#passwordDialog {
        background-color: #FFFFFF;
        border-radius: 20px;
        border: 3px solid #3498DB;
    }
    QLabel#passwordTitle {
        font-size: 22px;
        font-weight: bold;
        color: #2C3E50;
    }
    QLineEdit#passwordDisplay {
        font-size: 26px;
        min-height: 55px;
        border: 2px solid #BDC3C7;
        border-radius: 10px;
        padding: 5px 15px;
        background-color: #ECF0F1;
        font-family: "Consolas";
        letter-spacing: 5px;
    }
    QPushButton#num0, QPushButton#num1, QPushButton#num2, QPushButton#num3, QPushButton#num4,
    QPushButton#num5, QPushButton#num6, QPushButton#num7, QPushButton#num8, QPushButton#num9 {
        font-size: 22px;
        min-height: 55px;
        border-radius: 10px;
        font-weight: bold;
        background-color: #ECF0F1;
        color: #2C3E50;
    }
    QPushButton#num0:hover, QPushButton#num1:hover, QPushButton#num2:hover, QPushButton#num3:hover, QPushButton#num4:hover,
    QPushButton#num5:hover, QPushButton#num6:hover, QPushButton#num7:hover, QPushButton#num8:hover, QPushButton#num9:hover {
        background-color: #BDC3C7;
    }
    QPushButton#clearBtn {
        font-size: 22px;
        min-height: 55px;
        border-radius: 10px;
        font-weight: bold;
        background-color: #E67E22;
        color: white;
    }
    QPushButton#backspaceBtn {
        font-size: 22px;
        min-height: 55px;
        border-radius: 10px;
        font-weight: bold;
        background-color: #95A5A6;
        color: white;
    }
    QPushButton#confirmPasswordBtn {
        font-size: 22px;
        min-height: 55px;
        border-radius: 10px;
        font-weight: bold;
        background-color: #27AE60;
        color: white;
    }
    QPushButton#cancelPasswordBtn {
        font-size: 22px;
        min-height: 55px;
        border-radius: 10px;
        font-weight: bold;
        background-color: #E74C3C;
        color: white;
    }
   </string>
  </property>
  
