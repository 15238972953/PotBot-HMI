   </rect>
  </property>
  <property name="windowTitle">
   <string>智能花盆摆放控制系统</string>
  </property>
  <property name="styleSheet">
   <string>
    QMainWindow { background-color: #F0F2F5; }
    
    /* 容器组通用样式 */
    QGroupBox {
        background-color: #FFFFFF;
        border: 2px solid #DCDFE6;
        border-radius: 15px;
        margin-top: 20px;
        font-family: &quot;Microsoft YaHei&quot;;
        font-weight: bold;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        subcontrol-position: top left;
        padding: 5px 15px;
        color: #606266;
        font-size: 18px;
    }

    /* --- 数据区色块卡片 --- */
    QFrame#LatCard { background-color: #E3F2FD; border: 2px solid #2196F3; border-radius: 12px; }
    QFrame#LonCard { background-color: #E8F5E9; border: 2px solid #4CAF50; border-radius: 12px; }
    QFrame#YawCard { background-color: #FFFDE7; border: 2px solid #FBC02D; border-radius: 12px; }
    QFrame#CountCard { background-color: #F3E5F5; border: 2px solid #9C27B0; border-radius: 12px; }

    /* --- 设置区内部色块卡片 --- */
    QFrame#SpacingCard { background-color: #E0F7FA; border: 1px solid #00BCD4; border-radius: 10px; }
    QFrame#ModeCard { background-color: #FCE4EC; border: 1px solid #F06292; border-radius: 10px; }

    /* 文本样式 */
    QLabel { color: #303133; font-family: &quot;Microsoft YaHei&quot;; font-size: 18px; }
    QLabel#LatitudeValueLabel, QLabel#LongitudeValueLabel, QLabel#YawAngleValueLabel, QLabel#PotCountValueLabel {
        font-family: &quot;Consolas&quot;; font-size: 24px; font-weight: bold; color: #2D3436;
    }

    /* 按钮极大化设计 */
    QPushButton#SettingLabel { 
        background-color: #546E7A; color: white; border-radius: 15px; 
        min-height: 90px; font-size: 28px; font-weight: bold;
    }
    QPushButton#StartLabel { 
        background-color: #1976D2; color: white; border-radius: 15px; 
        min-height: 110px; font-size: 34px; font-weight: bold;
    }
    QPushButton:pressed { background-color: #263238; }

    /* 输入框尺寸调整 */
    QSpinBox, QComboBox {
        min-height: 65px;
        font-size: 22px;
        border: 2px solid #DCDFE6;
        border-radius: 8px;
        background-color: #FFFFFF;
    }
   </string>
