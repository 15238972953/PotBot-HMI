  <property name="styleSheet">
   <string>/* 浅色基调全局样式 */
QMainWindow {
    background-color: #F3F4F6;
}
QGroupBox {
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    margin-top: 15px;
    font-family: &quot;Microsoft YaHei&quot;;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
    left: 15px;
    color: #374151;
    font-weight: bold;
}
QLabel {
    color: #4B5563;
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 13px;
}
/* 强调数值的标签 */
QLabel#BatteryValueLabel { color: #10B981; font-weight: bold; font-size: 14px; }
QLabel#StatusValueLabel { color: #3B82F6; font-weight: bold; font-size: 14px; }
QLabel#LatitudeValueLabel, QLabel#LongitudeValueLabel, QLabel#YawAngleValueLabel {
    color: #111827; font-family: &quot;Consolas&quot;, monospace; font-weight: bold;
}
/* 输入框与下拉框 */
QSpinBox, QComboBox {
    padding: 6px;
    border: 1px solid #D1D5DB;
    border-radius: 4px;
    background-color: #F9FAFB;
    color: #1F2937;
}
QSpinBox:focus, QComboBox:focus { border: 1px solid #3B82F6; }
/* 按钮样式 */
QPushButton {
    border-radius: 6px;
    font-family: &quot;Microsoft YaHei&quot;;
    font-weight: bold;
}
QPushButton#SettingLabel {
    background-color: #FFFFFF;
    border: 1px solid #D1D5DB;
    color: #4B5563;
    padding: 10px;
}
QPushButton#SettingLabel:hover { background-color: #F3F4F6; }
QPushButton#StartLabel {
    background-color: #3B82F6;
    color: white;
    padding: 15px;
    font-size: 16px;
    border: none;
}
QPushButton#StartLabel:hover { background-color: #2563EB; }
QPushButton#StartLabel:pressed { background-color: #1D4ED8; }
/* 独特的相机与标题栏样式 */
QLabel#CaneraLabel {
    background-color: #111827;
    color: #9CA3AF;
    border-radius: 10px;
    border: 2px solid #93C5FD;
    font-size: 16px;
}
QGroupBox#titleLabel {
    background-color: transparent;
    border: none;
    margin-top: 0px;
}
QGroupBox#titleLabel::title {
    color: #111827;
    font-size: 18px;
    left: 0px;
}
</string>
